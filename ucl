<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>UCL 2026 | AI Predictor Engine</title>
    <style>
        :root {
            --ucl-blue: #003399;
            --ucl-gold: #d4af37;
            --glass: rgba(255, 255, 255, 0.05);
            --neon: #00f2ff;
        }
        body {
            background: radial-gradient(circle at center, #0a192f 0%, #020617 100%);
            color: white;
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            margin: 0;
            padding: 20px;
            min-height: 100vh;
        }
        .container { max-width: 1000px; margin: 0 auto; }
        .header { text-align: center; padding: 40px 0; border-bottom: 1px solid var(--glass); }
        .header h1 { font-size: 2.5rem; letter-spacing: 2px; color: var(--ucl-gold); margin: 0; }
        
        .api-input-section {
            background: var(--glass);
            padding: 20px;
            border-radius: 15px;
            margin: 20px 0;
            text-align: center;
            border: 1px solid rgba(212, 175, 55, 0.3);
        }
        input {
            padding: 10px;
            width: 300px;
            border-radius: 5px;
            border: none;
            margin-right: 10px;
        }
        button {
            padding: 10px 25px;
            background: var(--ucl-gold);
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
            transition: 0.3s;
        }
        button:hover { background: #fff; color: var(--ucl-blue); }

        #results { margin-top: 30px; display: none; }
        .card {
            background: rgba(16, 23, 41, 0.8);
            border: 1px solid var(--glass);
            border-radius: 15px;
            padding: 25px;
            margin-bottom: 20px;
            backdrop-filter: blur(10px);
        }
        .loading { font-style: italic; color: var(--neon); text-align: center; display: none; }
        .match-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
        .winner-crown { font-size: 3rem; text-align: center; margin-bottom: 10px; }
        .stats-badge { font-size: 0.75rem; background: var(--ucl-blue); padding: 4px 10px; border-radius: 10px; }
    </style>
</head>
<body>

<div class="container">
    <div class="header">
        <h1>CHAMPIONS LEAGUE 2026</h1>
        <p>Advanced AI Prediction Dashboard | March 18, 2026</p>
    </div>

    <div class="api-input-section">
        <input type="password" id="apiKey" placeholder="Enter OpenRouter API Key">
        <button onclick="generatePrediction()">Run AI Analysis</button>
    </div>

    <div id="loader" class="loading">Computing match probabilities and domestic form variables...</div>

    <div id="results">
        <div class="card" id="aiResponse">
            </div>
    </div>
</div>

<script>
async function generatePrediction() {
    const apiKey = document.getElementById('apiKey').value;
    const loader = document.getElementById('loader');
    const resultsDiv = document.getElementById('results');
    const responseBox = document.getElementById('aiResponse');

    if (!apiKey) {
        alert("Please enter an OpenRouter API key!");
        return;
    }

    loader.style.display = 'block';
    resultsDiv.style.display = 'none';

    const currentContext = `
        Current Date: March 18, 2026.
        Context: UCL Quarter-Finals are set.
        Teams in Play: Arsenal (1st in PL), Real Madrid (UCL kings, 2nd La Liga), PSG (Ligue 1 leaders), Bayern Munich (Bundesliga leaders), Barcelona (Top of La Liga), Sporting CP, Atlético Madrid, and Liverpool (struggling 6th in PL).
        Notable News: Mbappé is Madrid's top scorer. Real Madrid just beat Man City 5-1 on aggregate. PSG beat Chelsea 8-2.
        Request: Predict the QF, SF, and Final. For each match, provide score, goal scorers, and a "Form Contrast" (how their league performance affects them). Make it look like a professional tactical report. Use HTML tags for formatting.
    `;

    try {
        const response = await fetch("https://openrouter.ai/api/v1/chat/completions", {
            method: "POST",
            headers: {
                "Authorization": `Bearer ${apiKey}`,
                "Content-Type": "application/json"
            },
            body: JSON.stringify({
                "model": "google/gemini-2.0-flash-001", 
                "messages": [
                    {"role": "system", "content": "You are a professional football analyst and data scientist."},
                    {"role": "user", "content": currentContext}
                ]
            })
        });

        const data = await response.json();
        const content = data.choices[0].message.content;
        
        responseBox.innerHTML = content;
        loader.style.display = 'none';
        resultsDiv.style.display = 'block';

    } catch (error) {
        alert("Error fetching prediction. Check your API key and internet connection.");
        loader.style.display = 'none';
    }
}
</script>

</body>
</html>
